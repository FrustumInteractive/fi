$(TARGET): $(OBJECTS) | dependencies init
	@echo ""
	@echo " Link:"
	@echo "" >> $(TARGET_BUILD_LOG)
	@echo " Link: $@" >> $(TARGET_BUILD_LOG)
	@echo " Command: $(CXX) $(LDFLAGS) -o $@ $^ $(LIBS)" >> $(TARGET_BUILD_LOG)
	@tmp_log=$$(mktemp -t fi_target_XXXXXX.log); \
	if $(CXX) $(LDFLAGS) -o $@ $^ $(LIBS) > $$tmp_log 2>&1; then \
		cat $$tmp_log; \
		cat $$tmp_log >> $(TARGET_BUILD_LOG); \
		rm -f $$tmp_log; \
	else \
		cat $$tmp_log; \
		cat $$tmp_log >> $(TARGET_BUILD_LOG); \
		rm -f $$tmp_log; \
		exit 1; \
	fi

dependencies: $(DEPENDENCIES)
	@echo ""
	@echo " Building prerequesite project: $^"
	@mkdir -p $(BUILD_LOG_DIR)
	@set -e; \
	for x in $^; do \
		project_name=$$(basename $$x); \
		project_log="$(BUILD_LOG_DIR)/$$project_name.log"; \
		echo ""; \
		echo " ----- [$$project_name] begin -----"; \
		if $(MAKE) -C $$x $(MAKECMDGOALS) > $$project_log 2>&1; then \
			cat $$project_log; \
			echo " ----- [$$project_name] end -----"; \
		else \
			cat $$project_log; \
			exit 1; \
		fi; \
	done

init:
	@echo ""
	@echo "*************************************"
	@echo "	Building: $(TARGET)"
	@echo "*************************************"
	@echo " Compiler: $(CXX)"
	@echo " CXXFLAGS: $(CXXFLAGS)"
	@echo " DEFINES:  $(DEFINES)"
	@echo " Executing pre-build clean commands..."
	@$(POSTBUILDCLEAN)
	@mkdir -p $(BUILD_LOG_DIR)
	@rm -f $(TARGET_BUILD_LOG)
	@echo "*************************************" >> $(TARGET_BUILD_LOG)
	@echo " Building: $(TARGET)" >> $(TARGET_BUILD_LOG)
	@echo "*************************************" >> $(TARGET_BUILD_LOG)
	@echo " Compiler: $(CXX)" >> $(TARGET_BUILD_LOG)
	@echo " CXXFLAGS: $(CXXFLAGS)" >> $(TARGET_BUILD_LOG)
	@echo " DEFINES:  $(DEFINES)" >> $(TARGET_BUILD_LOG)
	
finish: $(TARGET)
	@echo ""
ifeq ($(WEB), 1)
	@echo " Moving binary and JavaScript file to web folder:"
	@mkdir -p web
	$(MV) $(TARGET) $(TARGET).wasm web$(SLASH)
	@if [ -f $(TARGET).data ]; then $(MV) $(TARGET).data web$(SLASH); fi
	@echo ""
endif
	@echo " Executing post build commands..."
	@$(POSTBUILD)
	@echo " Writing ordered build log: $(BUILD_LOG_FILE)"
	@set -e; \
	rm -f $(BUILD_LOG_FILE); \
	for x in $(DEPENDENCIES); do \
		project_name=$$(basename $$x); \
		project_log="$(BUILD_LOG_DIR)/$$project_name.log"; \
		if [ -f $$project_log ]; then \
			cat $$project_log >> $(BUILD_LOG_FILE); \
			echo "" >> $(BUILD_LOG_FILE); \
		fi; \
	done; \
	if [ -f $(TARGET_BUILD_LOG) ]; then \
		cat $(TARGET_BUILD_LOG) >> $(BUILD_LOG_FILE); \
		echo "" >> $(BUILD_LOG_FILE); \
	fi
	@echo ""
	@echo "*Build completed.*"
	@echo ""

.PHONY: clean

deepclean: clean
	@set -e; \
	for x in $(DEPENDENCIES); do \
		$(MAKE) -C $$x clean; \
	done

clean:
	$(RM) $(CLEAN_TARGET)
	$(RM) web$(SLASH)$(CLEAN_TARGET).worker.js
	$(RM) web$(SLASH)$(CLEAN_TARGET).wasm
	$(RM) web$(SLASH)$(CLEAN_TARGET).data
	$(RM) web$(SLASH)$(CLEAN_TARGET)
	$(RM) $(OBJDIR)
	$(RM) core.*
	$(RM) src$(SLASH)moc_*
	$(POSTBUILDCLEAN)
