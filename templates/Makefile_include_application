SOURCEDIR?=src
TOPDIR?=../..
INCDIR+=-I./include -I/usr/include -I./external -I$(TOPDIR)/include -I$(TOPDIR)/projects -I$(TOPDIR)/external
LIBDIR+=-L/usr/lib

CC=gcc
CXX=g++
CXXFLAGS+=$(INCDIR) -Wall -std=c++17 $(EXTRACXXFLAGS)
OBJCFLAGS+=$(INCDIR) -fmodules
OBJCXXFLAGS+=$(INCDIR) -std=c++17 -fmodules $(EXTRACXXFLAGS)
LDFLAGS+=$(LIBDIR)
INFLAGS?=
DEFINES?=
ARCH?=

LIBS=$(LIBS_LINUX)

RESOURCES?=
BUILD_LOG_DIR?=.buildlogs
BUILD_LOG_FILE?=build.log
TARGET_BUILD_LOG:=$(BUILD_LOG_DIR)/$(TARGET).log

### Tool / OS specific substitutions
RM=rm -rf
CP=cp
MV=mv
SLASH=/
CMDSEP=;

### Operating system specific defines, etc.
ifdef WEB
	DEFINES +=-DWEB -D_GLES2 $(CXXFLAGS_WEB)
	C_FILES +=$(C_FILES_WEB)
	CXX_FILES +=$(CXX_FILES_WEB)
	DEPENDENCIES +=$(DEP_WEB)
	CXXFLAGS =$(INCDIR) -std=c++17 -sUSE_SDL=2 -O3 $(EXTRACXXFLAGS)
	LIBS=$(LIBS_WEB)
	LDFLAGS +=$(LIBDIR) -sWASM=1 -sUSE_SDL=2 -O3 -sALLOW_MEMORY_GROWTH --emrun
	#LDFLAGS +=$(LIBDIR) -s WASM=1 -s USE_SDL=2 -sMIN_WEBGL_VERSION=2 -sMAX_WEBGL_VERSION=2 -sFULL_ES3 -sFULL_ES2 -O3 -s ALLOW_MEMORY_GROWTH --emrun --preload-file assets
	CC =emcc
	CXX =em++
else
	ifeq ($(OS),Windows_NT)
		DEFINES += -DWIN32
		ifeq ($(PROCESSOR_ARCHITECTURE),AMD64)
			DEFINES += -DAMD64
		endif
		ifeq ($(PROCESSOR_ARCHITECTURE),x86)
			DEFINES += -DIA32
		endif

		LIBS=$(LIBS_W32)
		CLEAN_TARGET=$(TARGET).exe
		C_FILES += $(C_FILES_WIN)
		CXX_FILES += $(CXX_FILES_WIN)
		INCDIR +=\
			-I$(TOPDIR)/extern/glew-1.13.0/include
		LIBDIR +=\
			-L$(TOPDIR)/extern/glew-1.13.0/lib/release/win32
		DEPTEMP := $(DEP_WIN32)
		DEPTEMP += $(DEPENDENCIES)
		DEPENDENCIES := $(DEPTEMP)
		
	ifndef BASH_EMU
		DEPENDENCIES := $(subst /,\\, $(DEPENDENCIES))
		RM=del /F /Q
		CP=copy
		SLASH=\\
		CMDSEP=&
	endif

	else
		UNAME_S := $(shell uname -s)
		UNAME_P := $(shell uname -m)

		ifeq ($(UNAME_S),Linux)
			DEFINES += -DLINUX
			C_FILES += $(C_FILES_LINUX)
			CXX_FILES += $(CXX_FILES_LINUX)
			LIBDIR+=\
				-L/usr/lib/x86-linux-gnu \
				-L/usr/lib/x86_64-linux-gnu
			DEPENDENCIES += $(DEP_LINUX)
		endif

		ifeq ($(UNAME_S),Darwin)
			LIBS=$(LIBS_OSX)
			DEFINES += -DOSX
			C_FILES += $(C_FILES_OSX)
			CXX_FILES += $(CXX_FILES_OSX)
			OBJC_FILES += $(OBJC_FILES_OSX)
			OBJCXX_FILES += $(OBJCXX_FILES_OSX)
			ifeq ($(ARCH),)
				ifeq ($(UNAME_P), x86_64)
					CXXFLAGS += -mmacosx-version-min=10.15 -arch x86_64
				endif
			else
				CXXFLAGS += -mmacosx-version-min=10.15 -arch arm64
				CCFLAGS += -mmacosx-version-min=10.15 -arch arm64
				OBJCFLAGS += -mmacosx-version-min=10.15 -arch arm64
				OBJCXXFLAGS += -mmacosx-version-min=10.15 -arch arm64
				LDFLAGS += -mmacosx-version-min=10.15 -arch arm64
			endif
			LIBDIR+=
			DEPENDENCIES += $(DEP_OSX)
			# include recipe text to make .app package
			include $(TOPDIR)/templates/Makefile_include_osx
		endif

		ifeq ($(UNAME_P),x86_64)
			DEFINES += -DAMD64
		endif
		ifneq ($(filter %86,$(UNAME_P)),)
			DEFINES += -DIA32
		endif
		ifneq ($(filter arm%,$(UNAME_P)),)
			DEFINES += -DARM
		endif
	endif ### windows
endif ### web

ifdef DEBUG
	CXXFLAGS += -g
	DEFINES += -D_DEBUG
endif

ifdef debug
	CXXFLAGS += -g
	DEFINES += -D_DEBUG
endif

### Set path for output object files
OBJDIR=obj
OBJECTS=$(patsubst %, $(OBJDIR)/%, $(C_FILES:.c=.o))
OBJECTS+=$(patsubst %, $(OBJDIR)/%, $(CXX_FILES:.cpp=.o))
OBJECTS+=$(patsubst %, $(OBJDIR)/%, $(OBJC_FILES:.m=.o))
OBJECTS+=$(patsubst %, $(OBJDIR)/%, $(OBJCXX_FILES:.mm=.o))


### add include & lib path from dependencies
INCDIR+=$(patsubst %, -I%/include, $(DEPENDENCIES))
LIBDIR+=$(patsubst %, -L%/lib, $(DEPENDENCIES))

all: finish

debug: CXXFLAGS += -g
debug: DEFINES += -D_DEBUG
debug: finish

debug2: CXXFLAGS += -g
debug2: DEFINES += -D_DEBUG
debug2: DEFINES += -D_DEBUG_2
debug2: finish

release: CXXFLAGS += -O3
release: finish

$(OBJDIR)/%.o: $(SOURCEDIR)/%.c | init
	@echo " Compile: $<"
	@mkdir -p $(dir $@)
	@echo " Compile: $<" >> $(TARGET_BUILD_LOG)
	@tmp_log=$$(mktemp -t fi_target_XXXXXX.log); \
	if $(CC) $(CXXFLAGS) $(DEFINES) -c -o $@ $< > $$tmp_log 2>&1; then \
		cat $$tmp_log; \
		cat $$tmp_log >> $(TARGET_BUILD_LOG); \
		rm -f $$tmp_log; \
	else \
		cat $$tmp_log; \
		cat $$tmp_log >> $(TARGET_BUILD_LOG); \
		rm -f $$tmp_log; \
		exit 1; \
	fi

