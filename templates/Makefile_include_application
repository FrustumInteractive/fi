	@echo " Compile: $<"
	@mkdir -p $(dir $@)
	@echo " Compile: $<" >> $(TARGET_BUILD_LOG)
	@tmp_log=$$(mktemp -t fi_target_XXXXXX.log); \
	if $(CXX) $(OBJCXXFLAGS) $(DEFINES) -c -o $@ $< > $$tmp_log 2>&1; then \
		cat $$tmp_log; \
		cat $$tmp_log >> $(TARGET_BUILD_LOG); \
		rm -f $$tmp_log; \
	else \
		cat $$tmp_log; \
		cat $$tmp_log >> $(TARGET_BUILD_LOG); \
